# ECZ-ID Credentials — Acquired from TrustOps (https://trustops.ecocitizenz.com/start)
# DO NOT commit real credentials to version control

# Your ECZ-ID Business Passport ID (parent)
ECZ_BUSINESS_PASSPORT_ID=

# Your ECZ-ID Agent Credential ID
ECZ_AGENT_CREDENTIAL_ID=

# API key issued by TrustOps
ECZ_API_KEY=

# TrustOps endpoint (do not change)
ECZ_TRUSTOPS_URL=https://trustops.ecocitizenz.com

# Resolver endpoint (do not change)
ECZ_RESOLVER_URL=https://resolver.ecocitizenz.org

# Agent display name
ECZ_AGENT_NAME=my-agent

# Deployment environment
ECZ_ENVIRONMENT=development

